{
  "manifest_version": 3,
  "name": "nxapi-browser",
  "version": "1.0.0",
  "description": "Refleja tu presencia de Nintendo Switch (via nxapi) como Rich Presence en Discord Web.",
  "author": "addictive-gamer",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://nxapi-presence.fancy.org.uk/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://discord.com/*"],
      "js": ["content-main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://discord.com/*"],
      "js": ["content-isolated.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
